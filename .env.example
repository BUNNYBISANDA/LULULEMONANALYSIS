PIPELINE_STATE_DB=data/state/pipeline_state.db
PIPELINE_DATA_DIR=data
PIPELINE_OUTPUT_DIR=public/data/dashboard_data
MAX_PAGES_PER_PRODUCT=1000
KNOWN_PAGE_STOP_THRESHOLD=2
MAX_REVIEWS_PER_PRODUCT_RUN=5000
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRY_ATTEMPTS=5
# Authorized browser cookie string for the live lululemon review source.
LULULEMON_COOKIE=
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_SECONDS=1800
LOW_STAR_MAX_RATING=3
CLASSIFIER_VERSION=keyword_v1
ML_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_VERSION=all-MiniLM-L6-v2
SEMANTIC_THRESHOLD=0.22
TAXONOMY_VERSION=master_defect_v1

# Backend (Express + PostgreSQL) configuration lives in backend/.env.example —
# see that file for DATABASE_URL / PG* / PORT variables.
