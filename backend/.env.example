# Copy this file to backend/.env and fill in real values. backend/.env is gitignored.

# If DATABASE_URL is set, it takes priority over the individual PG* variables below.
DATABASE_URL=

PGHOST=localhost
PGPORT=5432
PGDATABASE=lululemonvog
PGUSER=postgres
PGPASSWORD=CHANGE_ME
PGSSL=false

PGPOOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000

PORT=5000
