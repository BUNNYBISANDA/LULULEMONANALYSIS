# Runs the Express + MongoDB API that serves imported pipeline data.
# Build:  docker build -f Dockerfile.backend -t lululemon-dashboard-backend .
# Run:    docker run -p 5000:5000 --env-file backend/.env lululemon-dashboard-backend

FROM node:20-alpine
WORKDIR /app

COPY backend/package.json backend/package-lock.json ./
RUN npm ci --omit=dev

COPY backend/ .

ENV PORT=5000
EXPOSE 5000

CMD ["node", "server.js"]
